# OpenAI API Key (required)
OPENAI_API_KEY=sk-your-key-here

# Realtime model for voice session (ephemeral token)
REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17

# Base URL for local server
BASE_URL=http://localhost:8787

# ChromaDB persistent storage directory
CHROMA_PERSIST_DIR=./storage

# Directory containing knowledge base documents
DATA_DIR=./data

# LLM model for generating responses
LLM_MODEL=gpt-5-mini

# Embedding model for vector search
EMBEDDING_MODEL=text-embedding-3-small
